{
  "name": "roadmap-tracker-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npx vite build --config client/vite.config.js",
    "preview": "npm run preview --workspace client",
    "start": "npm run start --workspace server"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "@upstash/redis": "^1.34.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
